{
  "name": "outro-oss",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:run": "vitest run",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "turbo": "^2.7.6",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@3.6.4",
  "engines": {
    "node": ">=20"
  }
}

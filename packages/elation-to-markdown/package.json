{
  "name": "@outro/elation-to-markdown",
  "version": "0.1.0",
  "description": "Convert Elation EHR visit notes and non-visit notes to clean markdown",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
